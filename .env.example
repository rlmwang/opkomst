# Required — generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`
JWT_SECRET=
# Required — 32 raw bytes, base64-encoded.
# Generate with `python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"`
EMAIL_ENCRYPTION_KEY=

# SQLite for local dev; postgres://... for prod
DATABASE_URL=sqlite:///./opkomst.db

# Email backend: console (default) logs every send to structlog, smtp
# uses real SMTP (Scaleway TEM in production). Anything else falls
# through to console.
EMAIL_BACKEND=console

# SMTP — only consulted when EMAIL_BACKEND=smtp.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@opkomst.nu

# Right-hand side of outbound Message-ID headers. Should be a domain
# you control (e.g. "opkomst.nu"). Scaleway TEM webhooks quote the
# Message-ID back so we can correlate bounces to signups.
MESSAGE_ID_DOMAIN=opkomst.nu

# Shared secret for verifying Scaleway TEM webhook posts. When unset
# (dev) the webhook accepts all requests; in production this MUST be
# set to the secret configured in the TEM dashboard.
SCALEWAY_WEBHOOK_SECRET=

# Public base URL — the origin email links and QR codes resolve
# against. Must point at whichever host serves the SPA: in dev
# that's typically the Vite dev server (5173/5174), in prod it's
# the public domain (e.g. ``https://flatwork.nl``). If you're
# running uvicorn alone with ``frontend/dist`` mounted, set this
# to the uvicorn URL instead (``http://localhost:8000``).
PUBLIC_BASE_URL=http://localhost:5173

# Bootstrap admin: when set, the first user with this email auto-promotes to admin on registration.
BOOTSTRAP_ADMIN_EMAIL=

# When LOCAL_MODE=1, the backend seeds two test accounts on startup:
#   admin@local.dev / admin1234         (admin, approved)
#   organiser@local.dev / organiser1234 (organiser, approved)
# plus one upcoming and one past demo event. Idempotent — never touches
# rows it didn't create.
LOCAL_MODE=

# --- Production knobs ---------------------------------------------

# Comma-separated list of origins allowed to talk to the API. In prod
# the frontend ships from the same origin so this is rarely needed,
# but useful for staging / preview.
CORS_ORIGINS=http://localhost:5173

# Scheduler off-switch (set to 1 to skip the hourly feedback worker).
# Useful in tests or when running multiple replicas where only one
# replica should run the sweep.
DISABLE_SCHEDULER=

# Sentry — leave unset for dev. Set in production for error capture.
# SENTRY_ENVIRONMENT defaults to "production".
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0

# Rate-limit storage. ``memory://`` keeps state per-process — fine
# for a single uvicorn worker, but sharing across multiple workers
# / replicas requires Redis: set to ``redis://host:6379``.
RATE_LIMIT_STORAGE_URI=memory://

# uvicorn worker count for the prod container. The Dockerfile
# defaults to 4; bump for bigger boxes.
WEB_CONCURRENCY=4
